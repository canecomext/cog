{
  "version": "1.6.0",
  "workspace": ["./example"],
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19"
  },
  "tasks": {
    "setup:hooks": "cp .github/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit",
    "fmt": "deno fmt --ignore=example",
    "fmt:check": "deno fmt --ignore=example --check",
    "lint": "deno lint src/",
    "check": "deno check src/",
    "test": "deno test --allow-read --allow-write --coverage=cov/ test/generator.test.ts",
    "cov": "deno coverage --lcov cov/ > lcov.info"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 120,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
