{
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4.10.6",
    "@scalar/hono-api-reference": "npm:@scalar/hono-api-reference@^0.9.25",
    "@std/assert": "jsr:@std/assert@^1.0.16",
    "@std/crypto": "jsr:@std/crypto@^1.0.5",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.5",
    "@std/path": "jsr:@std/path@^1.1.3",
    "drizzle-orm": "npm:drizzle-orm@^0.44.7",
    "drizzle-zod": "npm:drizzle-zod@^0.8.3",
    "openapi-types": "npm:openapi-types@^12.1.3",
    "postgres": "npm:postgres@^3.4.7",
    "zod": "npm:zod@^4.1.12"
  },
  "compilerOptions": {
    "strict": true
  },
  "tasks": {
    "cog:crdb:generate": "deno run -A ../src/cli.ts --modelsPath ./models --outputPath ./generated --dbType cockroachdb",
    "cog:psql:generate": "deno run -A ../src/cli.ts --modelsPath ./models --outputPath ./generated --dbType postgresql",
    "db:init": "deno run -A ./db-init.ts",
    "db:clean": "deno run -A ./db-clean.ts",
    "fmt": "deno fmt --ignore=generated",
    "fmt:check": "deno fmt --ignore=generated --check",
    "lint": "deno lint db-init.ts db-clean.ts src/ test/ && deno lint generated/ --rules-exclude=no-unused-vars",
    "check": "deno check db-init.ts db-clean.ts src/ test/ generated/",
    "test:integration": "deno test -A --filter integration --coverage=cov/ test/integration.test.ts",
    "cov": "deno coverage --lcov cov/ > lcov.info"
  }
}
